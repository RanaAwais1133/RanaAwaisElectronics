{
    "framework":  "create-react-app",
    "buildCommand":  "DISABLE_ESLINT_PLUGIN=true npm run build",
    "installCommand":  "npm install",
    "outputDirectory":  "build",
    "env":  {
                "REACT_APP_API_URL":  "https://ranaawaiselectronics.onrender.com/api"
            },
    "routes":  [
                   {
                       "src":  "^/static/(.*)$",
                       "dest":  "/static/$1"
                   },
                   {
                       "src":  "^/(favicon\\.ico|manifest\\.json|logo\\d+\\.png|robots\\.txt|asset-manifest\\.json)$",
                       "dest":  "/$1"
                   },
                   {
                       "src":  "^/(.*)$",
                       "dest":  "/index.html"
                   }
               ],
    "devCommand":  "npm start"
}
