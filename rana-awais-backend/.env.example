# ═══════════════════════════════════════
# 🖥️ SERVER CONFIGURATION
# ═══════════════════════════════════════
SERVER_PORT=8080
ENVIRONMENT=production
FRONTEND_URL=https://your-domain.com
RATE_LIMIT_REQUESTS=100
MAX_BODY_SIZE_MB=10
ENABLE_HTTPS=true

# ═══════════════════════════════════════
# 🔐 AUTHENTICATION - CHANGE THESE!
# ═══════════════════════════════════════
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY_HOURS=24
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here
ADMIN_DISPLAY_NAME=Admin

# ═══════════════════════════════════════
# 🗄️ DATABASE
# ═══════════════════════════════════════
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGO_DB_NAME=myelectronics
USE_MONGO_DB=true
SQLITE_PATH=./rana-awais.db

# ═══════════════════════════════════════
# 🔑 LICENSE
# ═══════════════════════════════════════
LICENSE_KEY=your-license-key-here

# ═══════════════════════════════════════
# 🏢 COMPANY DETAILS
# ═══════════════════════════════════════
APP_NAME=My Electronics
COMPANY_NAME=My Electronics
COMPANY_NAME_UR=مائی الیکٹرانکس
BRANCH_NAME=Main Branch
BRANCH_NAME_UR=مرکزی شاخ
ADDRESS=Your Address Here
ADDRESS_UR=آپ کا پتہ یہاں

# ═══════════════════════════════════════
# 📞 CONTACT
# ═══════════════════════════════════════
PHONES=0300-0000000,0301-0000000

# ═══════════════════════════════════════
# 💻 SOFTWARE
# ═══════════════════════════════════════
SOFTWARE_BY=Your Name
SOFTWARE_BY_UR=آپ کا نام

# ═══════════════════════════════════════
# 📝 RECEIPT NOTES
# ═══════════════════════════════════════
INVOICE_NOTE=
INVOICE_NOTE_UR=نوٹ: مذکورہ بالا تفصیلات درست اور تصدیق شدہ ہیں۔
SERVICE_NOTE=
SERVICE_NOTE_UR=سروس چارجز میں صرف ایڈوانس شامل ہے

# ═══════════════════════════════════════
# 🔗 INTEGRATIONS
# ═══════════════════════════════════════
SMS_ENDPOINT=
WHATSAPP_API=
THERMAL_ENDPOINT=

# ═══════════════════════════════════════
# 💰 FINE SETTINGS
# ═══════════════════════════════════════
FINE_PER_DAY=0
FINE_MAX_PERCENT=0
GRACE_PERIOD_DAYS=0