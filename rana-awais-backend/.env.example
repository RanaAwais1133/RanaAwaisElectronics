# ============================================
# Rana Awais Electronics - Backend Environment
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================

# Server Configuration
SERVER_PORT=8080
# MongoDB Configuration
# For local MongoDB:
# MONGO_URI=mongodb://localhost:27017
# For MongoDB Atlas (add authMechanism=SCRAM-SHA-256 because SCRAM-SHA-1 is deprecated):
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<app-name>&authMechanism=SCRAM-SHA-256
DB_NAME=rana_awais_erp

# JWT Secret (Change in production! Use a strong random string)
JWT_SECRET=change-me-in-production

# SMS API Endpoint (Optional - leave empty if not used)
SMS_ENDPOINT=

# WhatsApp API Key (Optional - leave empty if not used)
WHATSAPP_API=

# Thermal Printer Endpoint (Optional - leave empty if not used)
THERMAL_ENDPOINT=
